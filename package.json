{
  "name": "gameku",
  "version": "1.0.0",
  "private": true,
  "description": "Digital Gaming Store",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:safe": "node kill-port.js && npm run dev",
    "start": "cd backend && npm start",
    "start:safe": "node kill-port.js && npm start",
    "kill-port": "node kill-port.js",
    "build": "node build.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "multer": "^2.2.0"
  }
}